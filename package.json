{
  "private": true,
  "scripts": {
    "local:backend": "cd backend && php artisan serve --port=8000",
    "local:web": "cd web && npm run dev",
    "local:start": "concurrently --names \"BACKEND,WEB\" --prefix-colors \"blue,orange\" \"npm run local:backend\" \"npm run local:web\""
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
