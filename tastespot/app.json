{
  "expo": {
    "name": "TasteSpot",
    "slug": "tastespot",
    "version": "1.0.0",
    "scheme": "tastespot",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAFA"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tastespot.app",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "package": "com.tastespot.app",
      "adaptiveIcon": {
        "backgroundColor": "#FAFAFA",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            { "scheme": "tastespot" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        },
        {
          "action": "SEND",
          "data": [
            { "mimeType": "text/plain" }
          ],
          "category": ["DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      "@maplibre/maplibre-react-native",
      [
        "expo-router",
        {
          "root": "./src/app"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "TasteSpot needs your location to show nearby activities."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "TasteSpot needs access to your photos to add pictures to activities.",
          "cameraPermission": "TasteSpot needs camera access to take photos of activities."
        }
      ],
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
